# Namespaced project name that the target belongs to
project: pgxmock

# Target name (should be unique within the project)
target: pgxmock

# List of commands used to test the target
cmds:

    # Command used to start the target using native Go fuzzing
    - cmd: /fuzzPgxmock -test.run=^$ -test.fuzz=FuzzPgxmock -test.fuzzcachedir=/tmp/fuzz
